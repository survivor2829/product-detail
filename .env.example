# ════════════════════════════════════════════════
# Platform API Keys (P3 砍刀流后必填)
# ════════════════════════════════════════════════
# 用户登录后不再自配 API key, 全部走 platform 托管.
# 缺任一项 app.py 启动直接 raise RuntimeError.

# DeepSeek (文案 AI 解析)
# 申请: https://platform.deepseek.com → 创建 API Key
DEEPSEEK_API_KEY=sk-xxx-deepseek

# gpt-image-2 (精修 v3.x 主管线)
# 通过 APIMart 等中转, 也可走 OpenAI 直连
REFINE_API_KEY=sk-xxx-refine

# 精修 API 实际 endpoint (反硬编码: 不留 fallback default URL)
# APIMart 示例: https://api.apimart.ai/v1
# OpenAI 直连: https://api.openai.com/v1
REFINE_API_BASE_URL=https://api.apimart.ai/v1

# 豆包 Seedream 4.0 (生图引擎之一, 走 localStorage 用户自管, 此 env 仅开发兜底)
# 申请: 火山方舟控制台 → API Key 管理 → 创建
# ARK_API_KEY=ark-xxx-doubao

# ════════════════════════════════════════════════
# Flask 应用密钥
# ════════════════════════════════════════════════

# Session 密钥 (生产环境必须设, 缺则 session cookie 可被伪造)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 字段加密密钥 (历史用于加密 user.custom_api_key_enc; P3 后保留兼容老数据)
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ════════════════════════════════════════════════
# 数据库
# ════════════════════════════════════════════════
# 默认 SQLite, 生产可换 PostgreSQL
# DATABASE_URL=sqlite:///instance/wubaoyun.db

# ════════════════════════════════════════════════
# 本地代理 (可选)
# ════════════════════════════════════════════════
# Clash 等代理时填; DeepSeek 走国内不走代理 (代码里 _clear_proxy 自动清)
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# ════════════════════════════════════════════════
# AI 背景图生成模式 (per CLAUDE.md AI_BG_MODE 章节)
# ════════════════════════════════════════════════
# cache    = 24h hash 缓存 (开发/内部测试推荐)
# realtime = 每次都实时调 Seedream (生产/对外 demo)
AI_BG_MODE=cache
