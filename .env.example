# 本地代理（可选，有 Clash 等代理时填写）
HTTP_PROXY=http://127.0.0.1:7890

# Flask Session 密钥（生产环境必须更换为随机值）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# API Key 加密密钥（用于加密存储用户自定义的 DeepSeek API Key）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=生成一个key填这里

# 数据库地址（默认 SQLite，可换 PostgreSQL）
# DATABASE_URL=sqlite:///wubaoyun.db

# ════════════════════════════════════════════════
# AI 生图 API Key — 不填则"AI 精修版"走 CSS 渐变兜底
# ════════════════════════════════════════════════
# 豆包 Seedream 4.0
# 申请: 火山方舟控制台 → 开通"图像生成" → 创建 API Key
# ARK_API_KEY=你的豆包key填这里
